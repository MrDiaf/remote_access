# Copy this file to .env and replace every placeholder before use.

COMPOSE_PROJECT_NAME=server-control-panel

DASHBOARD_BIND=0.0.0.0
DASHBOARD_HTTP_PORT=8080

# Bind privileged admin tools to localhost by default. Change to your VPN IP
# or a trusted private interface if you need browser access from another device.
PORTAINER_BIND=127.0.0.1
PORTAINER_HTTPS_PORT=9443
GUACAMOLE_BIND=127.0.0.1
GUACAMOLE_HTTP_PORT=8081

POSTGRES_DB=guacamole_db
POSTGRES_USER=guacamole_user
POSTGRES_PASSWORD=replace-with-a-strong-guacamole-db-password
